{
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": true,

  // cpptools reads build/compile_commands.json, which carries the /external:I
  // include roots from the toolchain file. That is the whole reason it can
  // find <vector> and <d3d12.h> without any environment being set up first.
  // Configure the project once before IntelliSense will work.
  "C_Cpp.default.compileCommands": "${workspaceFolder}/build/compile_commands.json",

  "files.associations": {
    "*.hlsl": "hlsl",
    "*.hlsli": "hlsl"
  },

  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.formatOnSave": true
  },
  "files.exclude": {
    "build": true,
    ".cache": true
  }
}
