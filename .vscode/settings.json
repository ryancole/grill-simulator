{
  "cmake.useCMakePresets": "always",
  "cmake.configureOnOpen": true,

  // clangd reads build/compile_commands.json, which carries the -vctoolsdir /
  // -winsdkdir flags from the toolchain file. That is the whole reason it can
  // find <vector> and <d3d12.h> without any environment being set up first.
  // Configure the project once before IntelliSense will work.
  "clangd.path": "C:\\Program Files\\LLVM\\bin\\clangd.exe",
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}/build",
    "--background-index",
    "--clang-tidy",
    "--header-insertion=never",
    "--pch-storage=memory"
  ],

  // cpptools is installed for its Windows debugger only. Two IntelliSense
  // engines over one translation unit produce duplicate, conflicting squiggles.
  "C_Cpp.intelliSenseEngine": "disabled",
  "C_Cpp.autocomplete": "disabled",
  "C_Cpp.errorSquiggles": "disabled",

  "files.associations": {
    "*.hlsl": "hlsl",
    "*.hlsli": "hlsl"
  },

  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true
  },
  "files.exclude": {
    "build": true,
    ".cache": true
  }
}
