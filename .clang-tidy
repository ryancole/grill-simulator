---
# Deliberately narrow. The D3D12 API is a C-style COM interface: raw pointers,
# out-params, reinterpret_cast and __uuidof are the idiom, not a code smell.
# Checks that fight the Windows and D3D12 headers are switched off rather than
# suppressed one call site at a time.
Checks: >
  bugprone-*,
  performance-*,
  readability-*,
  modernize-*,
  -bugprone-easily-swappable-parameters,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -readability-magic-numbers,
  -readability-function-cognitive-complexity

WarningsAsErrors: ''
HeaderFilterRegex: '^.*[/\\]src[/\\].*'
FormatStyle: file
