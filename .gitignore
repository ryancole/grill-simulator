# Every generated artifact lives under build/, including the fetched Agility
# SDK and DXC packages (build/_deps). Deleting this one directory is a
# complete reset.
build/

# Only reachable if a tool is run outside the presets: language-server caches
# and stray compilation databases written next to the source root.
.cache/
out/
compile_commands.json

# Editor and machine-local state, never generated by the build itself.
.vs/
CMakeUserPresets.json
*.user

# Per-user control overrides written by the in-game keybinds editor. It normally
# lives next to the exe under build/ (already ignored), but never belongs in the
# repo wherever it lands -- the committed controls.toml holds the shipped defaults.
controls.user.toml

# tools/gen_models.py is a script, not a package, but importing it to poke at a
# texture leaves this behind.
__pycache__/
