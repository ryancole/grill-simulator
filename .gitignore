# Every generated artifact lives under build/, including clangd's index
# (build/.cache) and the fetched Agility SDK and DXC packages (build/_deps).
# Deleting this one directory is a complete reset.
build/

# Only reachable if a tool is run outside the presets: clangd falls back to
# writing its index next to the source root when it cannot resolve the
# compilation database under build/.
.cache/
out/
compile_commands.json

# Editor and machine-local state, never generated by the build itself.
.vs/
CMakeUserPresets.json
*.user

# tools/gen_models.py is a script, not a package, but importing it to poke at a
# texture leaves this behind.
__pycache__/
